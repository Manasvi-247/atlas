# Copy this file to .env.local and fill in the values.
#   cp .env.local.example .env.local

# ── Claude ──────────────────────────────────────────────────────────────────
# Get a key at https://console.anthropic.com/ ("API Keys").
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model (defaults to claude-sonnet-4-6).
# ATLAS_MODEL=claude-sonnet-4-6

# ── Auth.js (Google sign-in) ─────────────────────────────────────────────────
# Generate a secret with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Google OAuth client from https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI (local): http://localhost:3000/api/auth/callback/google
#   Authorized redirect URI (prod):  https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# In production set this to your full site URL (e.g. https://atlas.vercel.app).
# AUTH_URL=

# ── Database (Neon Postgres) ─────────────────────────────────────────────────
# Create a project at https://neon.tech and copy the connection strings.
#   DATABASE_URL = pooled connection (used by the app at runtime)
#   DIRECT_URL   = direct connection (used by `prisma migrate`)
DATABASE_URL=
DIRECT_URL=
